# ── Gemini ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── KakaoTalk ─────────────────────────────────────────────────────────────────
# Get from https://developers.kakao.com → 내 애플리케이션 → 앱 키 → REST API 키
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here

# Kakao Client Secret (카카오 로그인 → 보안 → Client Secret 코드)
KAKAO_CLIENT_SECRET=your_kakao_client_secret_here

# 논문 저장 폴더 (구글 드라이브 경로로 변경 가능)
# 예: PAPER_SAVE_DIR=C:\Users\user\Google Drive\My Drive\papers
PAPER_SAVE_DIR=paper

# Filled automatically by setup_kakao.py — do not edit manually
KAKAO_ACCESS_TOKEN=
KAKAO_REFRESH_TOKEN=
